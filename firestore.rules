rules_version = '2';

// ─────────────────────────────────────────────────────────────────────
//  OB Tools — Firestore security rules
//
//  Access model: no login. The app signs in anonymously, so every
//  device that opens the tool can read & write the shared tracking data.
//  Requiring auth != null (an anonymous token) keeps the database from
//  being writable by anonymous REST calls that never load the app.
//
//  Stored data is de-identified (room | masked name + clinical numbers
//  + predicted times). No patient IDs, no full names.
// ─────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // Per-patient tracking documents
    match /patients/{patientKey} {
      allow read, write: if request.auth != null;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
