rules_version = '2';

// ─────────────────────────────────────────────────────────────────────
//  OB Tools — Firestore security rules
//
//  Access model: Google sign-in + email allowlist.
//  Only verified Google accounts whose email is in STAFF may read/write.
//  Add a colleague by adding their Google email to the list below,
//  then run:  firebase deploy --only firestore:rules
// ─────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    function isStaff() {
      return request.auth != null
          && request.auth.token.email_verified == true
          && request.auth.token.email in [
              'leoleeviator@gmail.com'
              // , 'colleague@gmail.com'
          ];
    }

    // Per-patient tracking documents (de-identified: room | masked name)
    match /patients/{patientKey} {
      allow read, write: if isStaff();
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
